<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.billing.charge.calculation.internal.mapper.DiscountMapper">

    <!-- 할인 가입정보 resultMap -->
    <resultMap id="discountSubscriptionResultMap"
               type="com.billing.charge.calculation.internal.model.DiscountSubscription">
        <result property="contractId" column="CONTRACT_ID"/>
        <result property="discountId" column="DISCOUNT_ID"/>
        <result property="discountCode" column="DISCOUNT_CODE"/>
        <result property="discountName" column="DISCOUNT_NAME"/>
        <result property="startDate" column="START_DATE"/>
        <result property="endDate" column="END_DATE"/>
    </resultMap>

    <!-- 계약ID 리스트로 할인 가입정보 조회 (할인 기준정보 join 없음) -->
    <select id="selectDiscountSubscriptions" resultMap="discountSubscriptionResultMap">
        SELECT ds.CONTRACT_ID,
               ds.DISCOUNT_ID,
               ds.DISCOUNT_CODE,
               ds.DISCOUNT_NAME,
               ds.START_DATE,
               ds.END_DATE
          FROM DISCOUNT_SUBSCRIPTION ds
         WHERE ds.CONTRACT_ID IN
        <foreach collection="contractIds" item="contractId" open="(" separator="," close=")">
            #{contractId}
        </foreach>
    </select>

</mapper>
